<view class="page">
  <view class="panel">
    <view class="title">高中全学科学习助手</view>
    <view class="subtitle">当前开放语文作文，已预留全学科扩展架构</view>

    <view class="section-title">学科</view>
    <picker bindchange="onSubjectChange" range="{{subjectOptions}}" range-key="label">
      <view class="subject-picker">
        <text class="subject-value">{{subjectLabel}}</text>
        <text class="subject-tip">点击切换（其他学科即将上线）</text>
      </view>
    </picker>

    <view class="section-title">题目材料</view>
    <textarea
      class="material-input"
      value="{{materialText}}"
      maxlength="{{maxLength}}"
      bindinput="onMaterialInput"
      placeholder="请粘贴题目或材料（建议 60 字以上）"
      placeholder-class="placeholder"
    />
    <view class="counter">{{materialText.length}} / {{maxLength}}</view>

    <view class="section-title">作文文体（语文）</view>
    <radio-group class="style-group" bindchange="onStyleChange">
      <label wx:for="{{styleOptions}}" wx:key="value" class="style-item">
        <radio value="{{item.value}}" checked="{{item.value === style}}" color="#1F6FEB" />
        <text class="style-label">{{item.label}}</text>
      </label>
    </radio-group>

    <view class="actions">
      <button class="btn btn-secondary" bindtap="fillDemoMaterial">填入示例材料</button>
      <button class="btn btn-primary" loading="{{isGenerating}}" bindtap="onGenerate">生成建议</button>
    </view>

    <view class="hint">当前输出：材料要点、立意候选、结构化提纲、提分点清单</view>
  </view>
</view>
