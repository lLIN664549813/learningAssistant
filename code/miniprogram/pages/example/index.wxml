<view class="page">
  <view wx:if="{{!hasResult}}" class="empty-card">
    <view class="empty-title">暂无生成结果</view>
    <view class="empty-desc">请先在首页输入材料并生成建议</view>
    <button class="btn-primary" bindtap="onRegenerate">返回首页</button>
  </view>

  <view wx:else>
    <view class="header-card">
      <view class="header-title">学习建议结果</view>
      <view class="header-meta">学科：{{subjectLabel}} · 模块：{{featureLabel}} · 文体：{{styleLabel}} · 生成时间：{{generatedAtText}}</view>
      <view class="header-actions">
        <button class="btn-secondary" bindtap="onRegenerate">重新生成</button>
        <button class="btn-primary" bindtap="onCopyResult">复制结果</button>
      </view>
    </view>

    <view wx:if="{{adSlotEnabled}}" class="ad-slot-card">
      <ad wx:if="{{adUnitId}}" unit-id="{{adUnitId}}" ad-type="banner" ad-theme="white" />
      <view wx:else class="ad-slot-placeholder"></view>
    </view>

    <view class="section-card" wx:for="{{sections}}" wx:key="index">
      <view class="section-title">{{item.title}}</view>

      <view wx:if="{{item.viewType === 'cards'}}">
        <view class="card-item" wx:for="{{item.entries}}" wx:for-item="entry" wx:key="index">
          <view class="card-title">{{index + 1}}. {{entry.title}}</view>
          <view wx:if="{{entry.desc}}" class="card-desc">{{entry.desc}}</view>
          <view class="card-bullet" wx:for="{{entry.bullets}}" wx:for-item="bullet" wx:key="index">- {{bullet}}</view>
        </view>
      </view>

      <view wx:else>
        <view class="list-item" wx:for="{{item.entries}}" wx:for-item="entry" wx:key="index">{{index + 1}}. {{entry.text}}</view>
      </view>
    </view>

    <view wx:if="{{hasSafetyNotes}}" class="section-card">
      <view class="section-title">提示</view>
      <view class="tip-item" wx:for="{{resultData.safety_notes}}" wx:key="index">{{index + 1}}. {{item}}</view>
    </view>
  </view>
</view>
